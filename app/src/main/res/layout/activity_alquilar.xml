<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Botón para abrir el selector de rango de fechas -->
    <Button
        android:id="@+id/btnAbrirCalendario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/seleccionar_rango_de_fechas"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- TextView para mostrar las fechas seleccionadas -->
    <TextView
        android:id="@+id/textoRangoFechas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/rango_seleccionado_aparecer_aqu"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@+id/btnAbrirCalendario"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
